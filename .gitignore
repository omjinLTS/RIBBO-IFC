# --- Python ---
**/__pycache__
**/*.pyc

# --- experiment outputs that are large / regenerable ---
# Keep generated data, cache, and results in the repo (used to resume work on
# another machine). Only the bulky intermediate training snapshots are excluded:
# all *.ckpt are ignored, then the final checkpoint per run is force-added.
log/**/*.ckpt
wandb
saved_log
scripts/ckpt_configs
plot/*
!plot/*.py

# --- copyrighted papers (do not redistribute) ---
/*.pdf

# --- local session / scratch files ---
.session_restart.log
.last_session_restart
log_convergence.txt

# --- LaTeX build artifacts ---
*.aux
*.log
*.out
*.nav
*.snm
*.toc
*.vrb
*.synctex.gz

# --- toy / smoke / false-start training runs (not needed) ---
log/ifc/dt-ee-d10-h1000-TOY
log/ifc/dt-ifc-d20-TOY
log/ifc/dt-ifc-ee-d20-TOY
log/synthetic/mini-smoke
log/ifc/dt-ifc-d20-3ba/IFCSED20-seed0-06-24-20-03-782785
log/ifc/dt-ifc-run1/IFCSE-seed0-05-18-11-31-94205
